# Clerk Authentication
# Get your keys from https://clerk.com (Dashboard > API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# Convex Database
# Run `npx convex deploy` in production
CONVEX_DEPLOYMENT=your-production-deployment
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Google Calendar Integration
# Get keys from https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_API_KEY=your-api-key

# Local LLM (Privacy-Focused AI)
LOCAL_AI_PROVIDER=ollama
LOCAL_AI_URL=http://localhost:11434
LOCAL_AI_MODEL=llama3.2
LOCAL_AI_TEMPERATURE=0.7
LOCAL_AI_MAX_TOKENS=2048